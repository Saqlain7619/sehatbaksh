# Port number
PORT=5000

# Postgres URL
DATABASE_URL="postgresql://postgres:saqlain123@localhost:5432/postgres"# JWT
# ======================
JWT_SECRET=thisisasamplesecret

# Access token expiry (JWT expects number OR short string like 7d, 1h)
JWT_EXPIRES_IN=7d

# (OPTIONAL – future use, not used right now)
JWT_REFRESH_EXPIRES_IN=30d
JWT_RESET_PASSWORD_EXPIRES_IN=60m
JWT_VERIFY_EMAIL_EXPIRES_IN=60m

# SMTP configuration options for the email service
# For testing, you can use a fake SMTP service like Ethereal: https://ethereal.email/create
SMTP_HOST=email-server
SMTP_PORT=587
SMTP_USERNAME=email-server-username
SMTP_PASSWORD=email-server-password
EMAIL_FROM=support@yourapp.com
